{
  "rulebook_version": 1,
  "name": "mise-rules",
  "version": "1.0.0",
  "description": "Block destructive mise run tasks — destroy-*",
  "author": "homelab.sklein.xyz",
  "allowed_commands": ["mise"],
  "rules": [
    {
      "name": "block-mise-run-destroy",
      "command": "mise",
      "subcommand": "run",
      "block_args": [
        "destroy-traefik",
        "destroy-grafana",
        "destroy-victoria-metrics",
        "destroy-authelia",
        "destroy-cnpg",
        "destroy-cnpg-memex",
        "destroy-homepage",
        "destroy-exporters",
        "destroy-zigbee",
        "destroy-cnpg-hindsight",
        "destroy-whoami",
        "destroy-authelia-demo",
        "destroy-cnpg-dummy-cluster"
      ],
      "reason": "mise run destroy-* scripts can delete infrastructure. Ask the user for confirmation first."
    }
  ],
  "tests": [
    { "command": "mise run destroy-traefik", "expect": "blocked", "rule": "block-mise-run-destroy" },
    { "command": "mise run destroy-cnpg-memex", "expect": "blocked", "rule": "block-mise-run-destroy" },
    { "command": "mise run destroy-zigbee", "expect": "blocked", "rule": "block-mise-run-destroy" },
    { "command": "mise run destroy-grafana", "expect": "blocked", "rule": "block-mise-run-destroy" },
    { "command": "mise run destroy-authelia", "expect": "blocked", "rule": "block-mise-run-destroy" },
    { "command": "mise run destroy-cnpg", "expect": "blocked", "rule": "block-mise-run-destroy" },
    { "command": "mise run destroy-homepage", "expect": "blocked", "rule": "block-mise-run-destroy" },
    { "command": "mise run destroy-exporters", "expect": "blocked", "rule": "block-mise-run-destroy" },
    { "command": "mise run destroy-victoria-metrics", "expect": "blocked", "rule": "block-mise-run-destroy" },
    { "command": "mise run destroy-cnpg-hindsight", "expect": "blocked", "rule": "block-mise-run-destroy" },
    { "command": "mise run destroy-whoami", "expect": "blocked", "rule": "block-mise-run-destroy" },
    { "command": "mise run destroy-authelia-demo", "expect": "blocked", "rule": "block-mise-run-destroy" },
    { "command": "mise run destroy-cnpg-dummy-cluster", "expect": "blocked", "rule": "block-mise-run-destroy" },
    { "command": "mise run deploy-traefik", "expect": "allowed" },
    { "command": "mise run k3s-health", "expect": "allowed" },
    { "command": "mise run backup-cnpg-memex", "expect": "allowed" },
    { "command": "mise run setup-secret", "expect": "allowed" },
    { "command": "mise run deploy-cnpg-hindsight", "expect": "allowed" },
    { "command": "mise run push-grafana-dashboards", "expect": "allowed" },
    { "command": "mise version", "expect": "allowed" },
    { "command": "mise ls", "expect": "allowed" }
  ]
}
