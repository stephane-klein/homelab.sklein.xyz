# vim: set filetype=yaml :
variant: fcos
version: 1.6.0
systemd:
  units:
    - name: getty@tty1.service
      dropins:
      - name: autologin-core.conf
        contents: |
          [Service]
          ExecStart=
          ExecStart=-/usr/sbin/agetty --autologin stephane --noclear %I $TERM

    - name: serial-getty@ttyS0.service
      dropins:
      - name: autologin-core.conf
        contents: |
          [Service]
          # Override Execstart in main unit
          ExecStart=
          # Add new Execstart with `-` prefix to ignore failure`
          ExecStart=-/usr/sbin/agetty --autologin stephane --noclear %I $TERM

    # Installing some packages as a layered package with rpm-ostree
    - name: rpm-ostree-install-1.service
      enabled: true
      contents: |
        [Unit]
        Description=Layer install some packages with rpm-ostree
        Wants=network-online.target
        After=network-online.target
        # We run before `zincati.service` to avoid conflicting rpm-ostree
        # transactions.
        Before=zincati.service
        ConditionPathExists=!/var/lib/%N.stamp

        [Service]
        Type=oneshot
        RemainAfterExit=yes
        ExecStart=/usr/bin/rpm-ostree install -y --allow-inactive neovim htop python3 netbird cockpit
        ExecStart=/bin/touch /var/lib/%N.stamp
        ExecStart=/usr/bin/systemctl enable netbird-setup.service
        ExecStart=/bin/systemctl --no-block reboot

        [Install]
        WantedBy=multi-user.target

    - name: netbird-setup.service
      enabled: false
      contents: |
        [Unit]
        Description=Configure Netbird with setup key
        Wants=network-online.target
        After=network-online.target
        Before=zincati.service
        ConditionPathExists=!/var/lib/netbird-setup.stamp

        [Service]
        Type=oneshot
        RemainAfterExit=yes
        ExecStartPre=/usr/bin/netbird service install
        ExecStartPre=/usr/bin/systemctl enable --now netbird
        ExecStart=/usr/bin/netbird up --setup-key {{ .Env.NUC_I7_GEN11_NETBIRD_SETUP_KEY }}
        ExecStart=/bin/touch /var/lib/netbird-setup.stamp

        [Install]
        WantedBy=multi-user.target

    - name: cockpit.socket
      enabled: true

    - name: cockpit-configure.service
      enabled: true
      contents: |
        [Unit]
        Description=Configure cockpit socket to listen on Netbird IP only
        After=netbird.service
        Requires=netbird.service
        ConditionPathExists=!/var/lib/cockpit-configure.stamp

        [Service]
        Type=oneshot
        RemainAfterExit=yes
        ExecStart=/bin/bash -c 'NETBIRD_IP=$(ip -4 addr show wt0 | grep -oP "(?<=inet\s)\d+(\.\d+){3}"); if [ -n "$NETBIRD_IP" ]; then mkdir -p /etc/systemd/system/cockpit.socket.d && printf "[Socket]\nListenStream=\nListenStream=%s:9090\n" "$NETBIRD_IP" > /etc/systemd/system/cockpit.socket.d/listen.conf && systemctl daemon-reload; fi; rm -f /etc/cockpit/ws-certs.d/0-self-signed-*.cert && sscg --hostname cockpit.$(hostname -f) --hostname $(hostname -f) && systemctl enable --now cockpit.socket || true'
        ExecStart=/bin/touch /var/lib/cockpit-configure.stamp

        [Install]
        WantedBy=multi-user.target

passwd:
  users:
    - name: root
      password_hash: "{{ .Env.NUC_I7_GEN11_STEPHANE_PASSWORD_HASH }}"
    - name: stephane
      groups:
        - wheel
        - sudo
      password_hash: "{{ .Env.NUC_I7_GEN11_STEPHANE_PASSWORD_HASH }}"
      ssh_authorized_keys:
        - ssh-rsa  contact@stephane-klein.info

storage:
  disks:
    - device: /dev/nvme0n1
      wipe_table: false
      partitions:
        - number: 4
          label: root
          size_mib: 15000
          resize: true
        - number: 5
          label: var
          size_mib: 0  # 0 = use all remaining space

  luks:
    - name: var
      device: /dev/disk/by-partlabel/var
      wipe_volume: true
      key_file:
        inline: "{{ .Env.NUC_I7_GEN11_LUKS_PASSPHRASE }}"
      clevis:
        tpm2: true
      
  filesystems:
    - path: /var
      device: /dev/mapper/var
      format: xfs
      wipe_filesystem: true
      label: var
      with_mount_unit: true

  files:
    - path: /etc/hostname
      mode: 0644
      contents:
        inline: |
          nuc-i7-gen11.homelab.stephane-klein.info

    # https://docs.fedoraproject.org/en-US/fedora-coreos/sysconfig-setting-keymap/
    - path: /etc/vconsole.conf
      mode: 0644
      contents:
        inline: |
          KEYMAP=fr-bepo
          FONT=eurlatgr

    - path: /etc/zincati/config.d/55-updates-strategy.toml
      mode: 0644
      contents:
        inline: |
          [updates]
          strategy = "periodic"
          
          [[updates.periodic.window]]
          days = [ "Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun" ]
          start_time = "02:00" # UTC
          length_minutes = 180

    - path: /etc/yum.repos.d/netbird.repo
      mode: 0644
      contents:
        inline: |
          [NetBird]
          name=NetBird
          baseurl=https://pkgs.netbird.io/yum/
          enabled=1
          gpgcheck=1
          gpgkey=https://pkgs.netbird.io/yum/repodata/repomd.xml.key
          repo_gpgcheck=1

    - path: /etc/cockpit/cockpit.conf
      mode: 0644
      contents:
        inline: |
          [WebService]
          Origins = https://cockpit.nuc-i7-gen11.homelab.stephane-klein.info:9090

  links:
    - path: /etc/localtime
      target: ../usr/share/zoneinfo/Europe/Paris
      overwrite: true
