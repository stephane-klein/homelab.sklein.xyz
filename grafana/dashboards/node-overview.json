{
  "title": "Node Overview",
  "uid": "node-overview",
  "tags": ["node", "system"],
  "schemaVersion": 39,
  "version": 0,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "refresh": "",
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "CPU Load",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "nuc-i7-gen11 — CPU Load",
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineInterpolation": "linear",
            "spanNulls": false,
            "showPoints": "auto",
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["last"]
        },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "node_load1{instance=\"nuc-i7-gen11.homelab.stephane-klein.info\", job=\"node-exporter\"}",
          "legendFormat": "Load 1m",
          "datasource": "Prometheus"
        },
        {
          "expr": "node_load5{instance=\"nuc-i7-gen11.homelab.stephane-klein.info\", job=\"node-exporter\"}",
          "legendFormat": "Load 5m",
          "datasource": "Prometheus"
